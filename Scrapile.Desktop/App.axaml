<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Scrapile.Desktop.App"
             xmlns:local="using:Scrapile.Desktop">
    <!-- Theme is set dynamically by ThemeService. Options: Light, Dark, System (default). -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />

        <!-- Make menu bar background lighter in dark mode for better contrast (Windows/Linux only) -->
        <Style Selector="Border#MenuBarBackground">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}" />
        </Style>
    </Application.Styles>
</Application>
