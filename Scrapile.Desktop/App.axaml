<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Scrapile.Desktop.App"
             xmlns:local="using:Scrapile.Desktop"
             RequestedThemeVariant="Light">
    <!-- Using "Light" theme for MVP. "Dark" or "Default" (system theme) are other options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>
