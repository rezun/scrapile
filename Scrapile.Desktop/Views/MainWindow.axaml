<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Scrapile.Desktop.ViewModels"
        xmlns:views="using:Scrapile.Desktop.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1024"
        d:DesignHeight="768"
        x:Class="Scrapile.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="1024"
        Height="768"
        MinWidth="600"
        MinHeight="400"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <!-- Main two-column layout: Tab list (left) | Editor (right) -->
    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Tab list panel - fixed initial width, resizable -->
            <ColumnDefinition Width="220" MinWidth="150" MaxWidth="400"/>
            <!-- Grid splitter -->
            <ColumnDefinition Width="Auto"/>
            <!-- Editor panel - takes remaining space -->
            <ColumnDefinition Width="*" MinWidth="300"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Tab List -->
        <views:TabListView Grid.Column="0"
                           DataContext="{Binding TabListViewModel}"/>

        <!-- Grid Splitter for resizing panels -->
        <GridSplitter Grid.Column="1"
                      Width="4"
                      Background="Transparent"
                      ResizeDirection="Columns"
                      ResizeBehavior="PreviousAndNext"/>

        <!-- Right Panel: Editor Area (placeholder for Task 4.4) -->
        <Border Grid.Column="2"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <!-- Title edit area -->
                    <RowDefinition Height="Auto"/>
                    <!-- Editor area -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Title edit area (placeholder) -->
                <Border Grid.Row="0"
                        Padding="16,12"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                        BorderThickness="0,0,0,1"
                        IsVisible="{Binding HasTabs}">
                    <TextBox Watermark="Add a title (optional)..."
                             IsEnabled="False"
                             BorderThickness="0"
                             Background="Transparent"
                             FontSize="16"
                             FontWeight="SemiBold"/>
                </Border>

                <!-- Main text editor area (placeholder) -->
                <TextBox Grid.Row="1"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="Wrap"
                         IsEnabled="False"
                         IsVisible="{Binding HasTabs}"
                         BorderThickness="0"
                         Padding="16"
                         FontFamily="Consolas, Menlo, Monaco, monospace"
                         FontSize="14"
                         Watermark="Start typing..."
                         VerticalContentAlignment="Top"/>
            </Grid>
        </Border>

        <!-- Empty state overlay (shown when no tabs are open) -->
        <Border Grid.Column="2"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                IsVisible="{Binding !HasTabs}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="16">
                <TextBlock Text="No tabs open"
                           FontSize="20"
                           Foreground="{DynamicResource TextControlForegroundDisabled}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Press Ctrl+T or click 'New Tab' to create a new tab"
                           FontSize="14"
                           Foreground="{DynamicResource TextControlForegroundDisabled}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>

</Window>
