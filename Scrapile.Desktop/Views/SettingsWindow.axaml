<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Scrapile.Desktop.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="500"
        d:DesignHeight="450"
        x:Class="Scrapile.Desktop.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="Settings"
        Width="500"
        Height="580"
        MinWidth="400"
        MinHeight="350"
        MaxHeight="700"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        ShowInTaskbar="False">

    <Design.DataContext>
        <vm:SettingsViewModel/>
    </Design.DataContext>

    <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
    <DockPanel Margin="16">
        <!-- Bottom buttons -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,16,0,0">
            <Button Content="Reset to Defaults"
                    Command="{Binding ResetToDefaultsCommand}"/>
            <Button Content="Close"
                    Command="{Binding CloseCommand}"
                    IsDefault="True"/>
        </StackPanel>

        <!-- Settings content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="24" Margin="0,0,16,0">

                <!-- Appearance Section -->
                <StackPanel Spacing="12">
                    <TextBlock Text="Appearance"
                               FontWeight="SemiBold"
                               FontSize="16"/>

                    <!-- Theme -->
                    <Grid ColumnDefinitions="150,*">
                        <TextBlock Text="Theme" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding Themes}"
                                  SelectedItem="{Binding SelectedTheme}"
                                  HorizontalAlignment="Stretch"/>
                    </Grid>

                    <!-- Tab Position -->
                    <Grid ColumnDefinitions="150,*">
                        <TextBlock Text="Tab Position" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding TabPositions}"
                                  SelectedItem="{Binding SelectedTabPosition}"
                                  HorizontalAlignment="Stretch"/>
                    </Grid>
                </StackPanel>

                <Separator/>

                <!-- Editor Section -->
                <StackPanel Spacing="12">
                    <TextBlock Text="Editor"
                               FontWeight="SemiBold"
                               FontSize="16"/>

                    <!-- Font Family -->
                    <Grid ColumnDefinitions="150,*">
                        <TextBlock Text="Font Family" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding FontFamilies}"
                                  SelectedItem="{Binding SelectedFontFamily}"
                                  HorizontalAlignment="Stretch"/>
                    </Grid>

                    <!-- Font Size -->
                    <Grid ColumnDefinitions="150,*,60">
                        <TextBlock Text="Font Size" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1"
                                Minimum="8"
                                Maximum="72"
                                Value="{Binding FontSize}"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding FontSize, StringFormat={}{0} pt}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- Word Wrap -->
                    <Grid ColumnDefinitions="150,*">
                        <TextBlock Text="Word Wrap" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding WordWrapOptions}"
                                  SelectedItem="{Binding SelectedWordWrap}"
                                  HorizontalAlignment="Stretch"/>
                    </Grid>

                    <!-- Always Show Line Numbers -->
                    <CheckBox Content="Always show line numbers"
                              IsChecked="{Binding AlwaysShowLineNumbers}"/>
                </StackPanel>

                <Separator/>

                <!-- Saving Section -->
                <StackPanel Spacing="12">
                    <TextBlock Text="Saving"
                               FontWeight="SemiBold"
                               FontSize="16"/>

                    <!-- Auto-Save Delay -->
                    <Grid ColumnDefinitions="150,*,70">
                        <TextBlock Text="Auto-Save Delay" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1"
                                Minimum="100"
                                Maximum="5000"
                                Value="{Binding AutoSaveDelayMs}"
                                TickFrequency="100"
                                IsSnapToTickEnabled="True"
                                VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding AutoSaveDelayMs, StringFormat={}{0} ms}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>

                <Separator/>

                <!-- Startup Section -->
                <StackPanel Spacing="12">
                    <TextBlock Text="Startup"
                               FontWeight="SemiBold"
                               FontSize="16"/>
                    <CheckBox Content="Start Scrapile when you log in"
                              IsChecked="{Binding AutorunAtStartup}"/>
                </StackPanel>

                <Separator/>

                <!-- System Tray Section -->
                <StackPanel Spacing="12">
                    <TextBlock Text="System Tray"
                               FontWeight="SemiBold"
                               FontSize="16"/>
                    <CheckBox Content="Always running in system tray"
                              IsChecked="{Binding RunInBackground}"/>
                    <TextBlock Text="When enabled, Scrapile stays in the system tray when you close the window. Required for global shortcuts."
                               FontSize="11"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Separator/>

                <!-- Global Shortcut Section -->
                <StackPanel Spacing="12">
                    <TextBlock Text="Global Shortcut"
                               FontWeight="SemiBold"
                               FontSize="16"/>
                    <TextBlock Text="Show/hide Scrapile from anywhere using a keyboard shortcut."
                               FontSize="12"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               TextWrapping="Wrap"/>

                    <!-- Disabled note when background mode is off -->
                    <TextBlock Text="Enable 'Always running in system tray' to use global shortcuts."
                               IsVisible="{Binding !IsGlobalShortcutEnabled}"
                               FontSize="11"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               FontStyle="Italic"
                               TextWrapping="Wrap"/>

                    <Grid ColumnDefinitions="*,Auto,Auto"
                          IsEnabled="{Binding IsGlobalShortcutEnabled}">
                        <TextBox x:Name="ShortcutTextBox"
                                 Grid.Column="0"
                                 Text="{Binding GlobalShortcut}"
                                 Watermark="No shortcut configured"
                                 IsReadOnly="True"
                                 IsVisible="{Binding !IsRecordingShortcut}"/>
                        <TextBox Grid.Column="0"
                                 Watermark="Press keys..."
                                 IsReadOnly="True"
                                 IsVisible="{Binding IsRecordingShortcut}"/>
                        <Button x:Name="RecordShortcutButton"
                                Grid.Column="1"
                                Content="Record"
                                Command="{Binding RecordShortcutCommand}"
                                IsEnabled="{Binding !IsRecordingShortcut}"
                                Margin="8,0,0,0"
                                MinWidth="100"/>
                        <Button Grid.Column="2"
                                Content="Clear"
                                Command="{Binding ClearShortcutCommand}"
                                IsEnabled="{Binding GlobalShortcut, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                Margin="4,0,0,0"/>
                    </Grid>

                    <!-- Conflict warning -->
                    <TextBlock Text="{Binding ShortcutConflictMessage}"
                               IsVisible="{Binding ShortcutConflictMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               Foreground="#E57D00"
                               FontSize="11"
                               TextWrapping="Wrap"/>

                    <!-- macOS Accessibility permission warning -->
                    <Border IsVisible="{Binding NeedsAccessibilityPermission}"
                            Background="#44E53935"
                            CornerRadius="4"
                            Padding="12,8">
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="12"
                                       Foreground="#E53935"
                                       TextWrapping="Wrap"
                                       Text="Accessibility permission required. Global shortcuts won't work until you grant permission."/>
                            <Button Content="Open System Settings"
                                    Command="{Binding OpenAccessibilitySettingsCommand}"
                                    HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <!-- macOS Accessibility note (when permission is granted) -->
                    <TextBlock IsVisible="{Binding HasAccessibilityPermission}"
                               FontSize="11"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               TextWrapping="Wrap">
                        <Run Text="Accessibility permission granted. You may need to restart the app after granting permission."/>
                    </TextBlock>

                    <!-- Wayland warning -->
                    <TextBlock IsVisible="{Binding IsWayland}"
                               FontSize="11"
                               Foreground="#E53935"
                               TextWrapping="Wrap">
                        <Run Text="Warning: Global shortcuts are not supported on Wayland. Consider using X11 for this feature."/>
                    </TextBlock>
                </StackPanel>

                <Separator/>

                <!-- Storage Section -->
                <StackPanel Spacing="12">
                    <TextBlock Text="Storage"
                               FontWeight="SemiBold"
                               FontSize="16"/>

                    <!-- Storage Directory -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Document Storage Directory"/>
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <TextBox Grid.Column="0"
                                     Text="{Binding StorageDirectory}"
                                     Watermark="Default: ~/Documents/Scrapile"
                                     IsReadOnly="True"/>
                            <Button Grid.Column="1"
                                    Content="Browse..."
                                    Command="{Binding BrowseStorageDirectoryCommand}"
                                    Margin="8,0,0,0"/>
                            <Button Grid.Column="2"
                                    Content="Reset"
                                    Command="{Binding ClearStorageDirectoryCommand}"
                                    Margin="4,0,0,0"/>
                        </Grid>
                        <TextBlock Text="Note: Changing storage directory requires app restart"
                                   FontSize="11"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>
                </StackPanel>

                <Separator/>

                <!-- Info Section -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Settings Location"
                               FontSize="11"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBlock Text="{Binding SettingsFilePath}"
                               FontSize="11"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
    </Border>
</Window>
