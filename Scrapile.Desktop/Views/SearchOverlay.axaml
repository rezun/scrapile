<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Scrapile.Desktop.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="500"
             d:DesignHeight="400"
             x:Class="Scrapile.Desktop.Views.SearchOverlay"
             x:DataType="vm:SearchViewModel">

    <UserControl.Resources>
        <vm:BoolToFontWeightConverter x:Key="BoolToFontWeightConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- Remove focus styling from search input - keep it clean and transparent -->
        <Style Selector="TextBox#SearchInput /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="TextBox#SearchInput:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="TextBox#SearchInput:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
    </UserControl.Styles>

    <!-- Semi-transparent backdrop that captures clicks to close -->
    <Panel Background="#50000000">
        <!-- Click on backdrop closes the overlay -->
        <Panel.Styles>
            <Style Selector="Panel">
                <Setter Property="Cursor" Value="Arrow"/>
            </Style>
        </Panel.Styles>

        <!-- Search modal dialog - centered -->
        <Border HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Margin="20,80,20,80"
                MaxWidth="850"
                MaxHeight="700"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="1"
                CornerRadius="8"
                BoxShadow="0 8 32 4 #30000000">

            <DockPanel>
                <!-- Header with search input -->
                <Border DockPanel.Dock="Top"
                        Padding="16,16,16,12"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                        BorderThickness="0,0,0,1">
                    <TextBox x:Name="SearchInput"
                             Text="{Binding SearchQuery, Mode=TwoWay}"
                             Watermark="Search documents..."
                             FontSize="16"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="0"/>
                </Border>

                <!-- Body: results list + preview pane -->
                <Grid ColumnDefinitions="300,*">
                    <!-- Left column: results area -->
                    <Panel Grid.Column="0">
                        <!-- Results list -->
                        <ScrollViewer x:Name="ResultsScrollViewer"
                                      IsVisible="{Binding HasResults}"
                                      >
                            <ItemsControl x:Name="ResultsItemsControl" ItemsSource="{Binding Results}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:SearchResultItemViewModel">
                                        <Border x:Name="ResultItem"
                                                Padding="16,10"
                                                Cursor="Hand">
                                            <Border.Styles>
                                                <Style Selector="Border#ResultItem">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                </Style>
                                                <Style Selector="Border#ResultItem:pointerover">
                                                    <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}"/>
                                                </Style>
                                                <Style Selector="Border#ResultItem.selected">
                                                    <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListAccentLowBrush}"/>
                                                </Style>
                                                <Style Selector="Border#ResultItem.selected:pointerover">
                                                    <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListAccentMediumBrush}"/>
                                                </Style>
                                            </Border.Styles>
                                            <Classes.selected>
                                                <Binding Path="IsSelected"/>
                                            </Classes.selected>

                                            <Grid RowDefinitions="Auto,Auto,Auto">
                                                <TextBlock Grid.Row="0"
                                                           Text="{Binding DisplayName}"
                                                           FontWeight="{Binding HasTitle, Converter={StaticResource BoolToFontWeightConverter}}"
                                                           FontSize="14"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxLines="1"/>

                                                <TextBlock Grid.Row="1"
                                                           Text="{Binding ContentSnippet}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxLines="1"
                                                           Margin="0,2,0,0"
                                                           IsVisible="{Binding HasTitle}"/>

                                                <TextBlock Grid.Row="2"
                                                           Text="{Binding LastModified}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                                           Margin="0,4,0,0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- No results message -->
                        <StackPanel IsVisible="{Binding ShowNoResults}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="0,40">
                            <TextBlock Text="No documents found"
                                       FontSize="14"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Try a different search term"
                                       FontSize="12"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Empty state (no query) -->
                        <StackPanel IsVisible="{Binding !HasResults}"
                                    IsEnabled="{Binding !ShowNoResults}">
                            <StackPanel.Styles>
                                <Style Selector="StackPanel:disabled">
                                    <Setter Property="IsVisible" Value="False"/>
                                </Style>
                            </StackPanel.Styles>
                            <TextBlock Text="Type to search all documents"
                                       FontSize="12"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,20"/>
                        </StackPanel>
                    </Panel>

                    <!-- Vertical separator -->
                    <Border Grid.Column="1"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                            BorderThickness="1,0,0,0">
                        <!-- Right column: preview pane -->
                        <Panel>
                            <!-- Content preview -->
                            <ScrollViewer IsVisible="{Binding HasPreviewContent}"
                                          Padding="16,12">
                                <TextBlock Text="{Binding SelectedPreviewContent}"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                           IsHitTestVisible="False"/>
                            </ScrollViewer>

                            <!-- Placeholder when nothing selected -->
                            <TextBlock IsVisible="{Binding !HasPreviewContent}"
                                       Text="Select a document to preview"
                                       FontSize="13"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Panel>
                    </Border>
                </Grid>
            </DockPanel>
        </Border>
    </Panel>

</UserControl>
