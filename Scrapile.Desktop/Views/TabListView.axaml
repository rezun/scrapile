<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Scrapile.Desktop.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="220"
             d:DesignHeight="600"
             x:Class="Scrapile.Desktop.Views.TabListView"
             x:DataType="vm:TabListViewModel"
             x:Name="TabListRoot">

    <UserControl.Resources>
        <vm:BoolToFontWeightConverter x:Key="BoolToFontWeightConverter"/>
    </UserControl.Resources>

    <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <!-- Tab list area -->
                <RowDefinition Height="*"/>
                <!-- New tab button area -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Tab list -->
            <ScrollViewer x:Name="TabScrollViewer"
                          Grid.Row="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          DragDrop.AllowDrop="True"
                          ScrollChanged="OnTabScrollChanged"
                          DoubleTapped="OnTabAreaDoubleTapped">
                <StackPanel>
                <ItemsControl ItemsSource="{Binding Tabs}"
                              Margin="4,4,4,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:TabItemViewModel">
                            <!-- Tab item using ListBoxItem-like styling -->
                            <Border x:Name="TabBorder"
                                    CornerRadius="4"
                                    Margin="0,0,0,2"
                                    Padding="8,6"
                                    Cursor="Hand"
                                    DragDrop.AllowDrop="True"
                                    PointerPressed="OnTabPointerPressed"
                                    PointerMoved="OnTabPointerMoved"
                                    PointerReleased="OnTabPointerReleased"
                                    Classes.selected="{Binding IsSelected}">

                                <Border.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuItem Header="Close Tab"
                                                  Click="OnContextMenuClose"/>
                                        <MenuItem Header="Close All Tabs"
                                                  Click="OnContextMenuCloseAll"/>
                                        <MenuItem Header="Close Tabs Above"
                                                  Click="OnContextMenuCloseAbove"/>
                                        <MenuItem Header="Close Tabs Below"
                                                  Click="OnContextMenuCloseBelow"/>
                                        <Separator/>
                                        <MenuItem Header="Duplicate Tab"
                                                  Click="OnContextMenuDuplicate"/>
                                        <MenuItem Header="Edit Title"
                                                  Click="OnContextMenuEditTitle"/>
                                        <Separator/>
                                        <MenuItem Header="Copy to Clipboard"
                                                  Click="OnContextMenuCopyToClipboard"/>
                                        <MenuItem Header="Save As..."
                                                  Click="OnContextMenuSaveAs"/>
                                        <Separator/>
                                        <MenuItem Header="Delete"
                                                  Click="OnContextMenuDelete"/>
                                    </MenuFlyout>
                                </Border.ContextFlyout>

                                <Border.Styles>
                                    <!-- Default state - use Border#TabBorder to target only this border, not menu items -->
                                    <Style Selector="Border#TabBorder">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Style>
                                    <!-- Hover state (not selected) -->
                                    <Style Selector="Border#TabBorder:pointerover:not(.selected)">
                                        <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}"/>
                                    </Style>
                                    <!-- Selected state -->
                                    <Style Selector="Border#TabBorder.selected">
                                        <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListAccentLowBrush}"/>
                                    </Style>
                                    <!-- Selected + hover state -->
                                    <Style Selector="Border#TabBorder.selected:pointerover">
                                        <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListAccentMediumBrush}"/>
                                    </Style>
                                </Border.Styles>

                                <Grid ColumnDefinitions="*,Auto">
                                    <!-- Tab content (title and stats) -->
                                    <StackPanel Grid.Column="0"
                                                Spacing="2"
                                                VerticalAlignment="Center">
                                        <!-- Title/Preview -->
                                        <Grid ColumnDefinitions="Auto,*">
                                            <Viewbox Grid.Column="0"
                                                     Width="13"
                                                     Height="13"
                                                     Margin="0,0,6,0"
                                                     Opacity="0.72"
                                                     VerticalAlignment="Center"
                                                     IsVisible="{Binding HasTitle}"
                                                     ToolTip.Tip="Titled tab">
                                                <Canvas Width="24" Height="24">
                                                    <Path Fill="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                                          Data="M6,2H14L20,8V20C20,21.1 19.1,22 18,22H6C4.9,22 4,21.1 4,20V4C4,2.9 4.9,2 6,2M13,3.5V9H18.5L13,3.5M8,13H16V11.5H8V13M8,16H16V14.5H8V16M8,19H13V17.5H8V19Z"/>
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding DisplayName}"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxLines="1"
                                                       FontWeight="{Binding HasTitle, Converter={StaticResource BoolToFontWeightConverter}}"
                                                       ToolTip.Tip="{Binding DisplayName}"/>
                                        </Grid>

                                        <!-- Stats subtitle -->
                                        <TextBlock Text="{Binding FormattedWordCount}"
                                                   FontSize="11"
                                                   Opacity="0.6"/>
                                    </StackPanel>

                                    <!-- Close button -->
                                    <Button Grid.Column="1"
                                            Command="{Binding CloseCommand}"
                                            VerticalAlignment="Center"
                                            Padding="4"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            ToolTip.Tip="Close tab"
                                            Cursor="Hand">
                                        <Button.Styles>
                                            <Style Selector="Button">
                                                <Setter Property="Opacity" Value="0.5"/>
                                            </Style>
                                            <Style Selector="Button:pointerover">
                                                <Setter Property="Opacity" Value="1"/>
                                                <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListMediumBrush}"/>
                                            </Style>
                                        </Button.Styles>
                                        <!-- X icon using path -->
                                        <PathIcon Data="M13.46,12L19,17.54V19H17.54L12,13.46L6.46,19H5V17.54L10.54,12L5,6.46V5H6.46L12,10.54L17.54,5H19V6.46L13.46,12Z"
                                                  Width="10"
                                                  Height="10"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- INLINE New Tab button - hidden when scrollable -->
                <Border x:Name="InlineNewTabButton"
                        Margin="4,0,4,4"
                        Padding="8,6"
                        CornerRadius="4"
                        Cursor="Hand"
                        IsVisible="{Binding !IsScrollable, ElementName=TabListRoot}"
                        PointerPressed="OnNewTabButtonPressed">
                    <Border.Styles>
                        <Style Selector="Border#InlineNewTabButton">
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                        <Style Selector="Border#InlineNewTabButton:pointerover">
                            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}"/>
                        </Style>
                    </Border.Styles>
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Text="+" FontSize="16" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                        <TextBlock Grid.Column="1" Text="New Tab" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" x:Name="InlineShortcutHint" Opacity="0.5" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Empty state message when no tabs -->
            <TextBlock Grid.Row="0"
                       Text="No tabs open"
                       IsVisible="{Binding !HasTabs}"
                       Foreground="{DynamicResource TextControlForegroundDisabled}"
                       FontStyle="Italic"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,20"/>

            <!-- FIXED New Tab button - only visible when scrollable -->
            <Border Grid.Row="1"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="4"
                    IsVisible="{Binding IsScrollable, ElementName=TabListRoot}">
                <Border x:Name="FixedNewTabButton"
                        Padding="8,6"
                        CornerRadius="4"
                        Cursor="Hand"
                        PointerPressed="OnNewTabButtonPressed">
                    <Border.Styles>
                        <Style Selector="Border#FixedNewTabButton">
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                        <Style Selector="Border#FixedNewTabButton:pointerover">
                            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}"/>
                        </Style>
                    </Border.Styles>
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Text="+" FontSize="16" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                        <TextBlock Grid.Column="1" Text="New Tab" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" x:Name="FixedShortcutHint" Opacity="0.5" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Border>
        </Grid>
    </Border>

</UserControl>
