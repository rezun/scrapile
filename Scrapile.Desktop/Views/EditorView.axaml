<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Scrapile.Desktop.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="600"
             d:DesignHeight="500"
             x:Class="Scrapile.Desktop.Views.EditorView"
             x:DataType="vm:EditorViewModel">

    <Design.DataContext>
        <vm:EditorViewModel/>
    </Design.DataContext>

    <UserControl.Styles>
        <!-- Remove focus border and set consistent background for editor TextBoxes -->
        <Style Selector="TextBox.editor-textbox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}"/>
        </Style>
        <Style Selector="TextBox.editor-textbox:focus">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}"/>
        </Style>
        <Style Selector="TextBox.editor-textbox:pointerover">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}"/>
        </Style>
        <Style Selector="TextBox.editor-textbox:focus-within">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}"/>
        </Style>
        <!-- Target the inner Border in the TextBox template -->
        <Style Selector="TextBox.editor-textbox /template/ Border#PART_BorderElement">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}"/>
        </Style>
        <Style Selector="TextBox.editor-textbox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}"/>
        </Style>
        <Style Selector="TextBox.editor-textbox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}"/>
        </Style>
    </UserControl.Styles>

    <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
        <Grid>
            <!-- Editor content (shown when a tab is selected) -->
            <Grid IsVisible="{Binding HasTab}">
                <Grid.RowDefinitions>
                    <!-- Title edit area -->
                    <RowDefinition Height="Auto"/>
                    <!-- Editor area -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Title edit area -->
                <Border Grid.Row="0"
                        Padding="16,12"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox x:Name="TitleTextBox"
                                 Grid.Column="0"
                                 Classes="editor-textbox"
                                 Text="{Binding Title, Mode=TwoWay}"
                                 Watermark="Add a title (optional)..."
                                 FontSize="16"
                                 FontWeight="SemiBold"
                                 AcceptsReturn="False"/>
                        <!-- Save status indicator -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding SaveStatus}"
                                   FontSize="12"
                                   Opacity="0.6"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </Grid>
                </Border>

                <!-- Main text editor area -->
                <TextBox x:Name="ContentTextBox"
                         Classes="editor-textbox"
                         Grid.Row="1"
                         Text="{Binding Content, Mode=TwoWay}"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="Wrap"
                         Padding="16"
                         FontFamily="{Binding EditorFontFamily}"
                         FontSize="{Binding EditorFontSize}"
                         Watermark="Start typing..."
                         VerticalContentAlignment="Top"/>
            </Grid>

            <!-- Empty state (shown when no tab is selected) -->
            <StackPanel IsVisible="{Binding !HasTab}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="16">
                <TextBlock Text="No tabs open"
                           FontSize="20"
                           Foreground="{DynamicResource TextControlForegroundDisabled}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Press Ctrl+T or click 'New Tab' to create a new tab"
                           FontSize="14"
                           Foreground="{DynamicResource TextControlForegroundDisabled}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>

</UserControl>
