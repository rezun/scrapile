<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Scrapile.Desktop.ViewModels"
             xmlns:views="using:Scrapile.Desktop.Views"
             xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             xmlns:aeEditing="clr-namespace:AvaloniaEdit.Editing;assembly=AvaloniaEdit"
             xmlns:converters="using:Scrapile.Desktop.Converters"
             mc:Ignorable="d"
             d:DesignWidth="600"
             d:DesignHeight="500"
             x:Class="Scrapile.Desktop.Views.EditorView"
             x:DataType="vm:EditorViewModel">

    <Design.DataContext>
        <vm:EditorViewModel/>
    </Design.DataContext>

    <UserControl.Resources>
        <converters:TextWrappingToBoolConverter x:Key="TextWrappingToBoolConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- Remove focus border and set consistent background for editor TextBoxes -->
        <Style Selector="TextBox.editor-textbox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}"/>
        </Style>
        <Style Selector="TextBox.editor-textbox:focus">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}"/>
        </Style>
        <Style Selector="TextBox.editor-textbox:pointerover">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}"/>
        </Style>
        <Style Selector="TextBox.editor-textbox:focus-within">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}"/>
        </Style>
        <!-- Target the inner Border in the TextBox template -->
        <Style Selector="TextBox.editor-textbox /template/ Border#PART_BorderElement">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}"/>
        </Style>
        <Style Selector="TextBox.editor-textbox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}"/>
        </Style>
        <Style Selector="TextBox.editor-textbox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}"/>
        </Style>
        <!-- AvaloniaEdit TextEditor styling -->
        <Style Selector="ae|TextEditor">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FocusAdorner" Value="{x:Null}"/>
        </Style>
        <Style Selector="ae|TextEditor:focus">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="ae|TextEditor:focus-visible">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <!-- Subtle status bar ComboBox styling -->
        <Style Selector="ComboBox.statusbar-combo">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Opacity" Value="0.7"/>
        </Style>
        <Style Selector="ComboBox.statusbar-combo:pointerover">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="ComboBox.statusbar-combo /template/ Border#Background">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="ComboBox.statusbar-combo:pointerover /template/ Border#Background">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ComboBox.statusbar-combo:pressed /template/ Border#Background">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ComboBox.statusbar-combo /template/ PathIcon#DropDownGlyph">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
        </Style>
    </UserControl.Styles>

    <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
        <Grid>
            <!-- Editor content (shown when a tab is selected) -->
            <Grid IsVisible="{Binding HasTab}">
                <Grid.RowDefinitions>
                    <!-- Find bar -->
                    <RowDefinition Height="Auto"/>
                    <!-- Title edit area -->
                    <RowDefinition Height="Auto"/>
                    <!-- Editor area -->
                    <RowDefinition Height="*"/>
                    <!-- Status bar -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Find bar -->
                <views:FindBarView x:Name="FindBar"
                                   Grid.Row="0"
                                   DataContext="{Binding FindViewModel}"
                                   IsVisible="{Binding $parent[views:EditorView].((vm:EditorViewModel)DataContext).IsFindBarVisible}"/>

                <!-- Title edit area -->
                <Border Grid.Row="1"
                        Padding="16,12"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox x:Name="TitleTextBox"
                                 Grid.Column="0"
                                 Classes="editor-textbox"
                                 Text="{Binding Title, Mode=TwoWay}"
                                 PlaceholderText="Add a title (optional)..."
                                 FontSize="16"
                                 FontWeight="SemiBold"
                                 AcceptsReturn="False"/>
                        <!-- Save status indicator -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding SaveStatus}"
                                   FontSize="12"
                                   Opacity="0.6"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </Grid>
                </Border>

                <!-- Main text editor area (AvaloniaEdit).
                     Text <-> Content binding is handled in code-behind because AvaloniaEdit's
                     Text property does not support direct two-way binding. -->
                <ae:TextEditor x:Name="ContentEditor"
                               Grid.Row="2"
                               WordWrap="{Binding TextWrapping, Converter={StaticResource TextWrappingToBoolConverter}}"
                               FontFamily="{Binding EditorFontFamily}"
                               FontSize="{Binding EditorFontSize}"
                               Padding="16"
                               ShowLineNumbers="{Binding ShowLineNumbers}"
                               HorizontalScrollBarVisibility="Auto"
                               VerticalScrollBarVisibility="Auto"/>

                <!-- Status bar -->
                <Border Grid.Row="3"
                        Padding="12,6"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                        BorderThickness="0,1,0,0">
                    <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding StatusText}"
                                   FontSize="12" Opacity="0.7"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding SelectionText}"
                                   FontSize="12" Opacity="0.7"
                                   Margin="16,0,0,0"
                                   IsVisible="{Binding HasSelection}"/>
                        <TextBlock x:Name="WordWrapText"
                                   Grid.Column="2"
                                   Text="{Binding WordWrapDisplayText}"
                                   FontSize="12"
                                   Opacity="0.7"
                                   Margin="16,0,0,0"
                                   Cursor="Hand"
                                   PointerPressed="OnWordWrapTextPressed"/>
                        <!-- Language selector -->
                        <ComboBox x:Name="LanguageComboBox"
                                  Grid.Column="3"
                                  Classes="statusbar-combo"
                                  ItemsSource="{Binding AvailableSyntaxLanguages.Keys}"
                                  SelectedItem="{Binding SyntaxLanguageDisplayText}"
                                  FontSize="12"
                                  Margin="16,0,0,0"
                                  VerticalAlignment="Center"
                                  Cursor="Hand"
                                  SelectionChanged="OnLanguageSelectionChanged"/>
                        <TextBlock Grid.Column="5"
                                   Text="{Binding CursorPositionText}"
                                   FontSize="12" Opacity="0.7"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Empty state (shown when no tab is selected) -->
            <StackPanel IsVisible="{Binding !HasTab}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="16">
                <TextBlock Text="No tabs open"
                           FontSize="20"
                           Foreground="{DynamicResource TextControlForegroundDisabled}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Press Ctrl+T or click 'New Tab' to create a new tab"
                           FontSize="14"
                           Foreground="{DynamicResource TextControlForegroundDisabled}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>

</UserControl>
